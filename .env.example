# ==========================================
# SUPABASE
# ==========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_URL=

# ==========================================
# STRIPE (pagos)
# ==========================================
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ==========================================
# REDSYS (TPV Virtual)
# ==========================================
REDSYS_MERCHANT_CODE=
REDSYS_SECRET_KEY=
REDSYS_TERMINAL=
REDSYS_URL=

# ==========================================
# RESEND (email)
# ==========================================
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=no-reply@sastreriaprats.com
RESEND_WEBHOOK_SECRET=
CONTACT_TEAM_EMAIL=info@sastreriaprats.com

# ==========================================
# NEWSLETTER
# ==========================================
# Clave HMAC para firmar tokens de opt-in y baja en los enlaces de los emails.
# Obligatoria para que funcionen /newsletter/confirmar y /newsletter/baja.
# Generar con: openssl rand -base64 32
# No cambiar en caliente: invalidaría todos los enlaces ya enviados.
NEWSLETTER_TOKEN_SECRET=

# ==========================================
# CRON
# ==========================================
CRON_SECRET=your-random-cron-secret-here

# ==========================================
# ANALYTICS
# ==========================================
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ==========================================
# PUSH NOTIFICATIONS
# ==========================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ==========================================
# DEMO / FEATURE FLAGS
# ==========================================
NEXT_PUBLIC_ENABLE_DEMO_PAYMENT=

# ==========================================
# AUTH
# ==========================================
CLIENT_DEFAULT_PASSWORD=

# Clave de cifrado de datos internos (32 bytes en base64).
# Generar con: openssl rand -base64 32  — guardar en Vercel y .env.local (server-only).
OPS_DATA_KEY=

# ==========================================
# TELEGRAM BOT + KIMI (consultas y reporte diario)
# ==========================================
# Token del bot de Telegram (BotFather).
TELEGRAM_BOT_TOKEN=
# Secreto que Telegram envía en cada webhook (cabecera X-Telegram-Bot-Api-Secret-Token).
# Generar con: openssl rand -hex 32. Se pasa a Telegram al registrar el webhook.
TELEGRAM_WEBHOOK_SECRET=
# Chats autorizados a consultar (ids numéricos separados por coma). Usa /id en el bot para verlos.
TELEGRAM_ALLOWED_CHAT_IDS=
# Chat (grupo) donde llega el reporte diario de facturación de las 21:30 (id negativo para grupos).
TELEGRAM_REPORT_CHAT_ID=
# API de Kimi (Moonshot), compatible OpenAI. Traduce lenguaje natural a SQL.
KIMI_API_KEY=
# Opcionales: modelo y base URL (por defecto kimi-k2.6 y https://api.moonshot.ai/v1).
KIMI_MODEL=
KIMI_API_BASE=

# ==========================================
# APP
# ==========================================
NEXT_PUBLIC_APP_URL=https://prats.fastia.es
NEXT_PUBLIC_APP_NAME=Sastrería Prats
